+-- --     _G.__YOLO__ = true
+-- --     _G.__WTF__ = true -- turn on if you want it to print scheduler tasks (useful if tasks start blocking for some reason)
+-- -- end
+-- _G.__REACT_MICROPROFILER_LEVEL__ = RunService:IsStudio() and 10 or 1
+-- _G.__PROFILE__ = RunService:IsStudio()
+-- _G.__EXPERIMENTAL__ = RunService:IsStudio()
+-- _G.__YOLO__ = true
+-- _G.__WTF__ = true -- turn on if you want it to print scheduler tasks (useful if tasks start blocking for some reason)
+
 return ReactGlobals
